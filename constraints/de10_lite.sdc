# =============================================================================
# DE10-Lite SDC Timing Constraints
# =============================================================================

# ── System clock constraint ─────────────────────────────────────────────────
# The board oscillator is 50 MHz but the single-cycle CPU achieves ~42 MHz
# Fmax (worst-case slow corner).  With derive_clock_uncertainty adding ~3 ns
# of pessimism, a 27 ns period (~37 MHz) is needed to close timing cleanly.
create_clock -name clk_50m -period 27.000 [get_ports MAX10_CLK1_50]

# ── Derived 25 MHz pixel clock (divider in top.sv) ─────────────────────────
# The pixel clock is generated by a toggle FF in top.sv → period = 40 ns.
create_generated_clock -name clk_pixel \
    -source [get_ports MAX10_CLK1_50] \
    -divide_by 2 \
    [get_registers {u_soc|clk_pixel}]

# ── Input / output delay (relaxed — buttons, VGA DAC) ──────────────────────
set_input_delay  -clock clk_50m -max 5.0 [get_ports {KEY[*]}]
set_input_delay  -clock clk_50m -min 0.0 [get_ports {KEY[*]}]

set_output_delay -clock clk_pixel -max 2.0 [get_ports {VGA_R[*] VGA_G[*] VGA_B[*] VGA_HS VGA_VS}]
set_output_delay -clock clk_pixel -min 0.0 [get_ports {VGA_R[*] VGA_G[*] VGA_B[*] VGA_HS VGA_VS}]

set_output_delay -clock clk_50m -max 2.0 [get_ports {LEDR[*] GPIO[*]}]
set_output_delay -clock clk_50m -min 0.0 [get_ports {LEDR[*] GPIO[*]}]

# ── Clock uncertainty (removes Critical Warning 332168) ─────────────────────
derive_clock_uncertainty

# ── False paths (async inputs — buttons) ────────────────────────────────────
set_false_path -from [get_ports {KEY[*]}]
