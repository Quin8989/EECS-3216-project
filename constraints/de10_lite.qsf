# Include search paths (for `include "constants.svh")
set_global_assignment -name SEARCH_PATH ../rtl/soc
set_global_assignment -name SEARCH_PATH ../rtl/cpu
set_global_assignment -name SEARCH_PATH ../rtl/periph

# Verilog macros for $readmemh paths (relative to constraints/ working dir)
set_global_assignment -name VERILOG_MACRO "MEM_PATH=\"../programs/keyboard_paint.x\""
set_global_assignment -name VERILOG_MACRO "SYNTHESIS=1"

set_global_assignment -name SYSTEMVERILOG_FILE ../rtl/soc/constants.svh
set_global_assignment -name SYSTEMVERILOG_FILE ../rtl/cpu/fetch.sv
set_global_assignment -name SYSTEMVERILOG_FILE ../rtl/cpu/cpu.sv
set_global_assignment -name SYSTEMVERILOG_FILE ../rtl/periph/ram.sv
set_global_assignment -name SYSTEMVERILOG_FILE ../rtl/periph/ps2_rx.sv
set_global_assignment -name SYSTEMVERILOG_FILE ../rtl/periph/keyboard.sv
set_global_assignment -name SYSTEMVERILOG_FILE ../rtl/periph/uart.sv
set_global_assignment -name SYSTEMVERILOG_FILE ../rtl/periph/timer.sv
set_global_assignment -name SYSTEMVERILOG_FILE ../rtl/periph/vga_fb.sv
set_global_assignment -name SYSTEMVERILOG_FILE ../rtl/soc/top.sv

# Intel JTAG-to-Avalon Master IP (Platform Designer generated)
set_global_assignment -name QIP_FILE ../ip/jtag_master/synthesis/jtag_master.qip
set_global_assignment -name SYSTEMVERILOG_FILE ../rtl/soc/top_fpga.sv

# Vendor IP: nullobject SDRAM controller (VHDL)
set_global_assignment -name VHDL_FILE ../rtl/vendor/sdram/sdram.vhd
